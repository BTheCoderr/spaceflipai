# Server-side secrets — NEVER commit real values.
# Production: supabase secrets set --env-file supabase/.env.local --project-ref YOUR_PROJECT_REF
# Local Edge Function dev only: copy to supabase/.env.local (gitignored)

GEMINI_API_KEY=
GROQ_API_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional provider controls (Edge Function secrets or supabase/.env.local)
# GEMINI_DISABLED=true          # skip Gemini entirely
# AI_PROVIDER_PREFERENCE=auto   # auto | gemini | groq

# --- Phase 18: AI concept image generation (OFF by default) ---
# Leave IMAGE_GENERATION_ENABLED unset/false to show the user's original property photo (no concept image).
# Only enable AFTER adding a provider key below.
# IMAGE_GENERATION_ENABLED=false           # true to turn on real image-to-image
# IMAGE_GENERATION_PROVIDER=replicate      # replicate | stability
# MAX_IMAGE_GENERATIONS_PER_USER_PER_DAY=5 # soft daily cost guard
#
# Provider keys — set ONLY ONE depending on IMAGE_GENERATION_PROVIDER.
# Never expose these in the Expo app. Never commit real values.
# REPLICATE_API_TOKEN=
# STABILITY_API_KEY=
