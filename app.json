{
  "expo": {
    "name": "SpaceFlip AI",
    "slug": "spaceflip-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "spaceflip",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "SpaceFlip AI needs camera access so you can take photos of rooms and spaces.",
        "NSPhotoLibraryUsageDescription": "SpaceFlip AI needs photo library access so you can choose room photos to redesign."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "SpaceFlip AI needs photo library access so you can choose room photos to redesign.",
          "cameraPermission": "SpaceFlip AI needs camera access so you can take photos of rooms and spaces."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
