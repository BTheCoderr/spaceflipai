{
  "expo": {
    "name": "SpaceFlip Pro",
    "slug": "spaceflip-pro",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "spaceflip",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F8F7F2"
    },
    "ios": {
      "icon": "./assets/icon.png",
      "supportsTablet": true,
      "bundleIdentifier": "com.spaceflip.pro",
      "buildNumber": "3",
      "infoPlist": {
        "NSCameraUsageDescription": "SpaceFlip Pro needs camera access so you can take a property or space photo for an upgrade plan.",
        "NSPhotoLibraryUsageDescription": "SpaceFlip Pro needs photo library access so you can select a property or space photo to create an upgrade plan.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.spaceflip.pro",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1B4332"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F8F7F2",
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "SpaceFlip Pro needs photo library access so you can select a property or space photo to create an upgrade plan.",
          "cameraPermission": "SpaceFlip Pro needs camera access so you can take a property or space photo for an upgrade plan.",
          "microphonePermission": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e8a0f765-6613-49b6-a8fe-a3a4a1566661"
      }
    }
  }
}
